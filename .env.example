# =============================================================
# igis 환경변수 견본 (.env.example)
#   사용법: 이 파일을 복사해 '.env' 로 만들고, 각 키에 실제 값을 채우세요.
#     Windows:  copy .env.example .env
#     Mac/Linux: cp .env.example .env
#   .env 는 .gitignore 로 제외되어 깃에 올라가지 않습니다.
# =============================================================

# 한국은행 경제통계시스템 (ECOS) — canaria, ciss 에서 사용
# 발급: https://ecos.bok.or.kr  → 오픈API → 인증키 신청
ECOS_API_KEY=

# Federal Reserve Economic Data (FRED) — canaria, ciss 에서 사용
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
